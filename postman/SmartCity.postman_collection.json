{
  "info": {
    "name": "Smart City Platform",
    "description": "Postman collection untuk Smart City Platform — mencakup OAuth, API Gateway, PHP Service, IoT Service, dan ML Service.",
    "_postman_id": "smart-city-platform-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",        "value": "http://localhost:3000",  "type": "string" },
    { "key": "PHP_URL",         "value": "http://localhost:8000",  "type": "string" },
    { "key": "ML_URL",          "value": "http://localhost:5000",  "type": "string" },
    { "key": "IOT_URL",         "value": "http://localhost:3001",  "type": "string" },
    { "key": "OAUTH_URL",       "value": "http://localhost:5001",  "type": "string" },
    { "key": "access_token",    "value": "",                       "type": "string" },
    { "key": "refresh_token",   "value": "",                       "type": "string" }
  ],
  "item": [
    {
      "name": "1. OAuth Server",
      "item": [
        {
          "name": "Get Token (Password Grant - User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token || '');",
                  "  console.log('Token saved:', res.data.access_token.substring(0, 30) + '...');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(res.data).to.have.property('access_token'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",    "value": "password" },
                { "key": "client_id",     "value": "laravel_web_dashboard" },
                { "key": "client_secret", "value": "secret_dashboard" },
                { "key": "username",      "value": "admin@smartcity.id" },
                { "key": "password",      "value": "password123" },
                { "key": "scope",         "value": "read write" }
              ]
            },
            "url": { "raw": "{{OAUTH_URL}}/token", "host": ["{{OAUTH_URL}}"], "path": ["token"] }
          }
        },
        {
          "name": "Get Token (Password Grant - Regular User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token || '');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",    "value": "password" },
                { "key": "client_id",     "value": "laravel_web_dashboard" },
                { "key": "client_secret", "value": "secret_dashboard" },
                { "key": "username",      "value": "budi@gmail.com" },
                { "key": "password",      "value": "password123" },
                { "key": "scope",         "value": "read" }
              ]
            },
            "url": { "raw": "{{OAUTH_URL}}/token", "host": ["{{OAUTH_URL}}"], "path": ["token"] }
          }
        },
        {
          "name": "Get Token (Client Credentials - IoT Gateway)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.data.access_token);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type",    "value": "client_credentials" },
                { "key": "client_id",     "value": "nodejs_iot_gateway" },
                { "key": "client_secret", "value": "secret_gateway" }
              ]
            },
            "url": { "raw": "{{OAUTH_URL}}/token", "host": ["{{OAUTH_URL}}"], "path": ["token"] }
          }
        },
        {
          "name": "Introspect Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token", "value": "{{access_token}}" }
              ]
            },
            "url": { "raw": "{{OAUTH_URL}}/introspect", "host": ["{{OAUTH_URL}}"], "path": ["introspect"] }
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "token",           "value": "{{access_token}}" },
                { "key": "token_type_hint", "value": "access_token" }
              ]
            },
            "url": { "raw": "{{OAUTH_URL}}/revoke", "host": ["{{OAUTH_URL}}"], "path": ["revoke"] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{OAUTH_URL}}/health", "host": ["{{OAUTH_URL}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "2. API Gateway",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/health", "host": ["{{BASE_URL}}"], "path": ["health"] }
          }
        },
        {
          "name": "Get Rooms (via Gateway)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{BASE_URL}}/php/api/rooms", "host": ["{{BASE_URL}}"], "path": ["php", "api", "rooms"] }
          }
        },
        {
          "name": "Get Room Comfort (via Gateway)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{BASE_URL}}/php/api/rooms/1/comfort", "host": ["{{BASE_URL}}"], "path": ["php", "api", "rooms", "1", "comfort"] }
          }
        },
        {
          "name": "Predict Busy Hour (via Gateway)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{BASE_URL}}/php/api/rooms/1/busy-hour", "host": ["{{BASE_URL}}"], "path": ["php", "api", "rooms", "1", "busy-hour"] }
          }
        }
      ]
    },
    {
      "name": "3. PHP Service — Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{PHP_URL}}/api/health", "host": ["{{PHP_URL}}"], "path": ["api", "health"] }
          }
        },
        {
          "name": "Get All Rooms",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{PHP_URL}}/api/rooms",
              "host": ["{{PHP_URL}}"],
              "path": ["api", "rooms"],
              "query": [{ "key": "zone_id", "value": "1", "disabled": true }]
            }
          }
        },
        {
          "name": "Get Room Comfort",
          "request": {
            "method": "GET",
            "url": { "raw": "{{PHP_URL}}/api/rooms/1/comfort", "host": ["{{PHP_URL}}"], "path": ["api", "rooms", "1", "comfort"] }
          }
        },
        {
          "name": "Get Room Comfort History (24 jam)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{PHP_URL}}/api/rooms/1/comfort/history", "host": ["{{PHP_URL}}"], "path": ["api", "rooms", "1", "comfort", "history"] }
          }
        },
        {
          "name": "Store Telemetry (Manual)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_id\": 1,\n  \"temperature\": 27.5,\n  \"humidity\": 60,\n  \"decibel_level\": 65\n}"
            },
            "url": { "raw": "{{PHP_URL}}/api/telemetry", "host": ["{{PHP_URL}}"], "path": ["api", "telemetry"] }
          }
        },
        {
          "name": "ML Callback (Simulate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telemetry_log_id\": 1,\n  \"ml_classification_status\": \"nyaman\",\n  \"predicted_next_busy_hour\": 10\n}"
            },
            "url": { "raw": "{{PHP_URL}}/api/telemetry/callback", "host": ["{{PHP_URL}}"], "path": ["api", "telemetry", "callback"] }
          }
        }
      ]
    },
    {
      "name": "4. PHP Service — User (Auth Required)",
      "item": [
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-User-Id",     "value": "2" },
              { "key": "X-User-Role",   "value": "user" }
            ],
            "url": { "raw": "{{PHP_URL}}/api/bookings", "host": ["{{PHP_URL}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-User-Id",     "value": "2" },
              { "key": "X-User-Role",   "value": "user" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"room_id\": 1,\n  \"seat_numbers\": [\"A1\", \"A2\"],\n  \"booking_date\": \"2026-06-30\",\n  \"start_time\": \"09:00\",\n  \"end_time\": \"11:00\"\n}"
            },
            "url": { "raw": "{{PHP_URL}}/api/bookings", "host": ["{{PHP_URL}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-User-Id",     "value": "2" },
              { "key": "X-User-Role",   "value": "user" }
            ],
            "url": { "raw": "{{PHP_URL}}/api/bookings/1", "host": ["{{PHP_URL}}"], "path": ["api", "bookings", "1"] }
          }
        },
        {
          "name": "Get Seat Recommendation",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-User-Id",     "value": "2" },
              { "key": "X-User-Role",   "value": "user" }
            ],
            "url": {
              "raw": "{{PHP_URL}}/api/rooms/1/recommend-seats?booking_date=2026-06-30&start_time=09:00&end_time=11:00&seat_count=2",
              "host": ["{{PHP_URL}}"],
              "path": ["api", "rooms", "1", "recommend-seats"],
              "query": [
                { "key": "booking_date", "value": "2026-06-30" },
                { "key": "start_time",   "value": "09:00" },
                { "key": "end_time",     "value": "11:00" },
                { "key": "seat_count",   "value": "2" }
              ]
            }
          }
        },
        {
          "name": "Get Busy Hour Prediction",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-User-Id",     "value": "2" },
              { "key": "X-User-Role",   "value": "user" }
            ],
            "url": { "raw": "{{PHP_URL}}/api/rooms/1/busy-hour", "host": ["{{PHP_URL}}"], "path": ["api", "rooms", "1", "busy-hour"] }
          }
        }
      ]
    },
