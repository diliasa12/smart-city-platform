        {
          "name": "Get Token — Admin (Password Grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token || '');",
                  "  console.log('✓ Token tersimpan:', res.data.access_token.substring(0, 40) + '...');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Ada access_token', () => pm.expect(res.data).to.have.property('access_token'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id", "value": "laravel_web_dashboard" },
                {
                  "key": "client_secret",
                  "value": "$2y$10$m9XyZzWvU87654321bK3bEeFzo1Sg8K2f689HjklMNOpQrStUvWabc"
